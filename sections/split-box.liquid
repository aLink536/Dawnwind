<section class="px-0! page-width {{ section.settings.padding_top }} {{ section.settings.padding_bottom }}">
  <div class="w-full flex {{ section.settings.image_position }} flex-wrap justify-center">
    <div class="w-full lg:w-1/2">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1300 | image_tag: class: 'w-full h-full object-cover' }}
      {% endif %}
    </div>

    <div class="flex lg:w-1/2 flex-col w-full gap-3 p-default color-scheme color-scheme--{{ section.settings.color_scheme }} {{ section.settings.content_vertical_position }} {{ section.settings.content_horizontal_position }}">
      {% render 'heading', heading: section.settings.heading, size: section.settings.heading_size %}

      {% if section.settings.subheading != blank %}
        <p class="">
          {{ section.settings.subheading }}
        </p>
      {% endif %}
      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <div class="flex flex-wrap gap-3">
          {% render 'button', text: section.settings.button_text, url: section.settings.button_link %}
          {% render 'button', text: section.settings.button_secondary_text, url: section.settings.button_secondary_link, style: 'secondary' %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.split_box",
  "settings": [
    {
      "type": "header",
      "content": "t:headers.image_settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "t:headers.text_settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:labels.heading_size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "t:options.heading_size.h1" },
        { "value": "h2", "label": "t:options.heading_size.h2" },
        { "value": "h3", "label": "t:options.heading_size.h3" },
        { "value": "h4", "label": "t:options.heading_size.h4" },
        { "value": "h5", "label": "t:options.heading_size.h5" }
      ]
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_secondary_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "t:headers.content_layout_settings"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "default": "flex-row-reverse",
      "options": [
        {
          "value": "flex-row",
          "label": "Left"
        },
        {
          "value": "flex-row-reverse",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_horizontal_position",
      "label": "Content horizontal position",
      "default": "items-center text-center",
      "options": [
        {
          "value": "items-start text-left",
          "label": "Left"
        },
        {
          "value": "items-center text-center",
          "label": "Center"
        },
        {
          "value": "items-end text-right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_vertical_position",
      "label": "Content vertical position",
      "default": "justify-center",
      "options": [
        {
          "value": "justify-start",
          "label": "Top"
        },
        {
          "value": "justify-center",
          "label": "Middle"
        },
        {
          "value": "justify-end",
          "label": "Bottom"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:headers.section_layout_settings"
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "default": "pt-16",
      "options": [
        { "value": "pt-0", "label": "t:options.padding_size.none" },
        { "value": "pt-8", "label": "t:options.padding_size.small" },
        { "value": "pt-16", "label": "t:options.padding_size.medium" },
        { "value": "pt-24", "label": "t:options.padding_size.large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "default": "pb-16",
      "options": [
        { "value": "pb-0", "label": "t:options.padding_size.none" },
        { "value": "pb-8", "label": "t:options.padding_size.small" },
        { "value": "pb-16", "label": "t:options.padding_size.medium" },
        { "value": "pb-24", "label": "t:options.padding_size.large" }
      ]
    },
    {
      "type": "header",
      "content": "t:headers.color_scheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Split box",
      "category": "Design"
    }
  ]
}
{% endschema %}
