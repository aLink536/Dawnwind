{% if section.blocks.size > 0 %}
  <section class="relative {{ section.settings.padding_top }} {{ section.settings.padding_bottom }} {% unless section.settings.full_width %}page-width{% endunless %}">
    <simple-slider class="relative block">
      <div
        class="flex overflow-x-auto scroll-smooth snap-x snap-mandatory focus:outline-none no-scrollbar"
        tabindex="0"
      >
        {% for block in section.blocks %}
          <div
            class="relative w-full overflow-hidden shrink-0 snap-start stack color-scheme color-scheme--{{ block.settings.color_scheme }}"
            {{ block.shopify_attributes }}
          >
            <div class="max-h-[60vh]">
              {% if block.settings.image_mobile %}
                {{
                  block.settings.image_mobile
                  | image_url: width: 1200
                  | image_tag: alt: 'Hero image (mobile)', class: 'w-full h-full object-cover block md:hidden'
                }}
              {% endif %}

              {% if block.settings.image_desktop %}
                {{
                  block.settings.image_desktop
                  | image_url: width: 2000
                  | image_tag: alt: 'Hero image (desktop)', class: 'w-full h-full object-cover hidden md:block'
                }}
              {% endif %}
            </div>
            <div class="page-width w-full text-center py-default flex flex-col gap-3 z-10 {{ block.settings.content_vertical_position }} {{ block.settings.content_horizontal_position }}">
              <div class="flex flex-col gap-3 w-full {{ block.settings.content_width }} {{ block.settings.content_vertical_position }} {{ block.settings.content_horizontal_position }}">
                {% render 'heading', heading: block.settings.heading, size: block.settings.heading_size %}

                {% if block.settings.subheading != blank %}
                  <p class="">
                    {{ block.settings.subheading }}
                  </p>
                {% endif %}
                {% if block.settings.button_text != blank and block.settings.button_link != blank %}
                  <div class="flex flex-wrap justify-center gap-3">
                    {% render 'button', text: block.settings.button_text, url: block.settings.button_link %}
                    {% render 'button', text: block.settings.button_secondary_text, url: block.settings.button_secondary_link, style: 'secondary' %}
                  </div>
                {% endif %}
              </div>
            </div>
            {% if block.settings.overlay_enabled %}
              <div class="absolute top-0 left-0 w-full h-full bg-black opacity-50"></div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if section.blocks.size > 1 %}
        <div class="absolute inset-y-0 left-0 right-0 z-20 flex items-center justify-between px-4 pointer-events-none">
          <button
            class="transition-opacity duration-200 ease-in-out rotate-180 pointer-events-auto cursor-pointer slider-nav aspect-square button-secondary"
            aria-label="Previous"
          >
            {{ 'icon-arrow.svg' | inline_asset_content }}
          </button>
          <button
            class="transition-opacity duration-200 ease-in-out pointer-events-auto cursor-pointer slider-nav aspect-square button-secondary"
            aria-label="Next"
          >
            {{ 'icon-arrow.svg' | inline_asset_content }}
          </button>
        </div>
      {% endif %}
    </simple-slider>
  </section>
{% endif %}

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "header",
      "content": "t:headers.section_layout_settings"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width section",
      "default": true
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "default": "pt-16",
      "options": [
        { "value": "pt-0", "label": "t:options.padding_size.none" },
        { "value": "pt-8", "label": "t:options.padding_size.small" },
        { "value": "pt-16", "label": "t:options.padding_size.medium" },
        { "value": "pt-24", "label": "t:options.padding_size.large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "default": "pb-16",
      "options": [
        { "value": "pb-0", "label": "t:options.padding_size.none" },
        { "value": "pb-8", "label": "t:options.padding_size.small" },
        { "value": "pb-16", "label": "t:options.padding_size.medium" },
        { "value": "pb-24", "label": "t:options.padding_size.large" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:blocks.slide",
      "settings": [
        {
          "type": "header",
          "content": "t:headers.image_settings"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Image (desktop)"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Image (mobile)"
        },
        {
          "type": "checkbox",
          "id": "overlay_enabled",
          "label": "Enable overlay",
          "default": false
        },
        {
          "type": "header",
          "content": "t:headers.text_settings"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "t:labels.heading_size",
          "default": "h2",
          "options": [
            { "value": "h1", "label": "t:options.heading_size.h1" },
            { "value": "h2", "label": "t:options.heading_size.h2" },
            { "value": "h3", "label": "t:options.heading_size.h3" },
            { "value": "h4", "label": "t:options.heading_size.h4" },
            { "value": "h5", "label": "t:options.heading_size.h5" }
          ]
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "text",
          "id": "button_secondary_text",
          "label": "Button text"
        },
        {
          "type": "url",
          "id": "button_secondary_link",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "t:headers.content_layout_settings"
        },
        {
          "type": "select",
          "id": "content_horizontal_position",
          "label": "Content horizontal position",
          "default": "items-center text-center",
          "options": [
            {
              "value": "items-start text-left",
              "label": "Left"
            },
            {
              "value": "items-center text-center",
              "label": "Center"
            },
            {
              "value": "items-end text-right",
              "label": "Right"
            }
          ]
        },
        {
          "type": "select",
          "id": "content_vertical_position",
          "label": "Content vertical position",
          "default": "justify-center",
          "options": [
            {
              "value": "justify-start",
              "label": "Top"
            },
            {
              "value": "justify-center",
              "label": "Middle"
            },
            {
              "value": "justify-end",
              "label": "Bottom"
            }
          ]
        },
        {
          "type": "select",
          "id": "content_width",
          "label": "Content width",
          "default": "md:w-2/3",
          "options": [
            {
              "value": "md:w-full",
              "label": "Full width"
            },
            {
              "value": "md:w-3/4",
              "label": "3/4 width"
            },
            {
              "value": "md:w-2/3",
              "label": "2/3 width"
            },
            {
              "value": "md:w-1/2",
              "label": "1/2 width"
            }
          ]
        },
        {
          "type": "header",
          "content": "t:headers.color_scheme"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "Color scheme"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Design",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
