<section class="gap-8 flex flex-col color-scheme color-scheme--{{ section.settings.color_scheme }} {{ section.settings.content_horizontal_position }} {{ section.settings.padding_top }} {{ section.settings.padding_bottom }}">
  <div class="w-full page-width px-default">
    {% render 'heading', heading: section.settings.heading, size: section.settings.heading_size, url: section.settings.collection.url %}

    {% if section.settings.collection != blank %}
      {% assign collection_handle = section.settings.collection %}
      {% assign collection = collections[collection_handle] %}

      {% if collection.products_count > 0 %}
        <simple-slider
          class="relative flex flex-col"
        >
          <div
            class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory focus:outline-none no-scrollbar"
            tabindex="0"
          >
            {% for product in collection.products limit: 10 %}
              <div class="snap-start shrink-0 w-[47%] lg:w-[23.5%]">
                {% render 'product-card', product: product %}
              </div>
            {% endfor %}
          </div>

          <div class="flex justify-between w-full ">
            <button
              class="transition-opacity duration-200 ease-in-out rotate-180 cursor-pointer slider-nav aspect-square button-secondary"
              aria-label="Previous"
            >
              {{ 'icon-arrow.svg' | inline_asset_content }}
            </button>
            <button
              class="transition-opacity duration-200 ease-in-out cursor-pointer slider-nav aspect-square button-secondary"
              aria-label="Next"
            >
              {{ 'icon-arrow.svg' | inline_asset_content }}
            </button>
          </div>
        </simple-slider>

        <div class="mt-6 text-center">
          {% render 'button', text: 'View All Products', url: collection.url %}
        </div>
      {% else %}
        <p>No products found in this collection.</p>
      {% endif %}
    {% else %}
      <p>Please select a collection to feature.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "t:general.featured_collection",
  "settings": [
    {
      "type": "header",
      "content": "t:headers.text_settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:labels.heading_size",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "t:options.heading_size.h1" },
        { "value": "h2", "label": "t:options.heading_size.h2" },
        { "value": "h3", "label": "t:options.heading_size.h3" },
        { "value": "h4", "label": "t:options.heading_size.h4" },
        { "value": "h5", "label": "t:options.heading_size.h5" }
      ]
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select collection"
    },
    {
      "type": "header",
      "content": "t:headers.content_layout_settings"
    },
    {
      "type": "select",
      "id": "content_horizontal_position",
      "label": "Content horizontal position",
      "default": "text-center",
      "options": [
        {
          "value": "text-left",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-right",
          "label": "Right"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:headers.section_layout_settings"
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "t:labels.padding_top",
      "default": "pt-16",
      "options": [
        { "value": "pt-0", "label": "t:options.padding_size.none" },
        { "value": "pt-8", "label": "t:options.padding_size.small" },
        { "value": "pt-16", "label": "t:options.padding_size.medium" },
        { "value": "pt-24", "label": "t:options.padding_size.large" }
      ]
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "t:labels.padding_bottom",
      "default": "pb-16",
      "options": [
        { "value": "pb-0", "label": "t:options.padding_size.none" },
        { "value": "pb-8", "label": "t:options.padding_size.small" },
        { "value": "pb-16", "label": "t:options.padding_size.medium" },
        { "value": "pb-24", "label": "t:options.padding_size.large" }
      ]
    },
    {
      "type": "header",
      "content": "t:headers.color_scheme"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    }
  ],
  "presets": [
    {
      "name": "Featured Collection",
      "category": "Collections"
    }
  ]
}
{% endschema %}
