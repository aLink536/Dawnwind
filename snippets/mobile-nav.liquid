<div class="flex flex-col h-full w-80 max-w-[80vw] bg-(--color-background) text-(--color-foreground)">
  
  <!-- Header -->
  <div class="flex items-center justify-between px-4 py-4 border-b border-(--color-border)">
    <span class="text-lg font-semibold">Menu</span>

    <button
      data-offcanvas-close
      class="flex items-center justify-center w-6 h-6 transition cursor-pointer hover:opacity-80"
      aria-label="Close Menu"
    >
      <span class="w-8 h-8 [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current">
        {{ 'icon-close.svg' | inline_asset_content }}
      </span>
    </button>
  </div>

  <!-- Menu Links -->
  <nav class="flex-1 pb-10 overflow-y-auto">
    {% if section.settings.menu != blank %}
      <ul class="flex flex-col">
        {% for link in section.settings.menu.links %}
          <li>
            <a
              href="{{ link.url }}"
              class="block px-4 py-3 text-base transition hover:bg-(--color-accent-hover) focus:bg-(--color-accent-hover) focus:outline-none"
            >
              {{ link.title }}
            </a>

            {% if link.links != blank %}
              <ul class="pl-6 border-l border-(--color-border) ml-4 space-y-1">
                {% for sublink in link.links %}
                  <li>
                    <a
                      href="{{ sublink.url }}"
                      class="block px-4 py-2 text-sm transition hover:bg-(--color-accent-hover) focus:bg-(--color-accent-hover) focus:outline-none"
                    >
                      {{ sublink.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  </nav>

  <!-- Footer -->
  <div class="px-4 py-4 border-t border-(--color-border) space-y-3">

    {% if shop.customer_accounts_enabled %}
      <a href="{{ routes.account_url }}" class="flex items-center gap-3">
        <span class="w-5 h-5 [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current">
          {{ 'icon-account.svg' | inline_asset_content }}
        </span>
        <span>Account</span>
      </a>
    {% endif %}
  </div>

</div>
